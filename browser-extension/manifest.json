{
  "manifest_version": 3,
  "name": "豆包梦幻皮肤",
  "short_name": "豆包皮肤",
  "version": "0.3.0",
  "description": "为网页版豆包添加完整主题预设、自定义组件、背景和智能文字配色。",
  "minimum_chrome_version": "109",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://doubao.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "css": [
        "content/content.css"
      ],
      "js": [
        "shared/defaults.js",
        "shared/color-engine.js",
        "content/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "豆包梦幻皮肤",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
